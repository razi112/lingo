# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for OAuth redirect URLs and self-referential links.
APP_URL="MY_APP_URL"

# ── Supabase ──────────────────────────────────────────────────────────────
# These are baked into src/lib/supabase.ts for this project.
# If you fork this project, replace them with your own project credentials.
# Dashboard → Project Settings → API
VITE_SUPABASE_URL="https://ysevronsxymysnpwvwlr.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ── Google OAuth (configured in Supabase Dashboard) ───────────────────────
# You do NOT need VITE_GOOGLE_CLIENT_ID here anymore.
# Configure Google as an OAuth provider in:
#   Supabase Dashboard → Authentication → Providers → Google
# Add your Google Client ID + Secret there, and set the redirect URL to:
#   https://<your-project>.supabase.co/auth/v1/callback
